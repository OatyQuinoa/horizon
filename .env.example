# PostgreSQL connection string (required for /api/ipos and db:ingest).
# Use your Supabase "Connection string" (URI) from: Project → Settings → Database.
# Format: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

